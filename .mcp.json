{
  "name": "tax-calculator-ai-mcp",
  "description": "AI-powered tax calculator ai MCP server for agents. Supports calculate income tax, calculate vat, estimate corporation tax. By MEOK AI Labs.",
  "version": "1.0.0",
  "tools": [
    {
      "name": "calculate_income_tax",
      "description": "Calculate income tax using UK or US progressive tax brackets.",
      "parameters": {
        "type": "object",
        "properties": {
          "income": {
            "type": "number"
          },
          "country": {
            "type": "string"
          },
          "filing_status": {
            "type": "string"
          },
          "include_ni": {
            "type": "boolean"
          }
        },
        "required": [
          "income"
        ]
      }
    },
    {
      "name": "calculate_vat",
      "description": "Calculate EU/UK VAT by country. Rate types: standard, reduced, zero.",
      "parameters": {
        "type": "object",
        "properties": {
          "amount": {
            "type": "number"
          },
          "country": {
            "type": "string"
          },
          "rate_type": {
            "type": "string"
          },
          "is_inclusive": {
            "type": "boolean"
          }
        },
        "required": [
          "amount"
        ]
      }
    },
    {
      "name": "estimate_corporation_tax",
      "description": "Estimate UK corporation tax including marginal relief calculations.",
      "parameters": {
        "type": "object",
        "properties": {
          "profit": {
            "type": "number"
          },
          "financial_year": {
            "type": "string"
          },
          "is_associated": {
            "type": "boolean"
          }
        },
        "required": [
          "profit"
        ]
      }
    },
    {
      "name": "calculate_capital_gains",
      "description": "Calculate UK Capital Gains Tax. Asset types: residential, other.",
      "parameters": {
        "type": "object",
        "properties": {
          "gain": {
            "type": "number"
          },
          "asset_type": {
            "type": "string"
          },
          "annual_income": {
            "type": "number"
          }
        },
        "required": [
          "gain"
        ]
      }
    },
    {
      "name": "get_tax_deadlines",
      "description": "Get upcoming tax filing and payment deadlines for UK or US.",
      "parameters": {
        "type": "object",
        "properties": {
          "country": {
            "type": "string"
          }
        },
        "required": []
      }
    }
  ]
}